# ============================================================
#  AlgoBot — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ============================================================

# ── Supabase (backend + local runner) ────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_KEY=your_service_role_key_here

# ── Supabase (frontend public keys — safe to expose in browser) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Backend API URL ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://algobot-backend.vercel.app

# ── Binance ───────────────────────────────────────────────────
BINANCE_BASE_URL=https://data-api.binance.vision
BINANCE_DEMO_URL=https://testnet.binance.vision
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Vercel (for CLI deploy) ───────────────────────────────────
VERCEL_TOKEN=your_vercel_token_here
VERCEL_TEAM=your_team_slug_here

# ── Render ────────────────────────────────────────────────────
RENDER_API_KEY=your_render_api_key_here
